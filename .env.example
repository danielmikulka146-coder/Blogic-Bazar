# Google OAuth — vytvoř si OAuth Client ID na https://console.cloud.google.com
# (APIs & Services → Credentials → Create credentials → OAuth client ID → Web application).
# Do "Authorized JavaScript origins" přidej http://localhost:3000 (a doménu produkce).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# Veřejná URL webu (pro odkaz v emailu)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Gmail SMTP — emailové notifikace při nové zprávě v chatu
# Vygeneruj App Password na https://myaccount.google.com/apppasswords (vyžaduje 2FA)
GMAIL_USER=
GMAIL_APP_PASSWORD=
